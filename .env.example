# Copy to ".env" and/or ".env.local" (Next.js loads both; .env.local overrides).
# Generate local machine secrets: npm run env:generate
# New ingest key only (then push to Vercel): npm run env:rotate-ingest-key && npm run vercel:env:push
# Push these keys to Vercel: npm run vercel:env:push (see scripts/sync-vercel-env.cjs)

# --- MongoDB (required for listings, meetups, locations, site copy in DB) ---
MONGODB_URI=
# Database name passed to MongoClient.db(). Use a dedicated name (e.g. budapest-night).
# Use a dedicated database name — db:seed wipes listings on the target DB.
MONGODB_DB=budapest-night
# Optional: Atlas UI may show MONGODB_APP_NAME; the driver usually reads appName from the URI query string instead.
# MONGODB_APP_NAME=

# --- ImgBB (server upload key + public CDN URLs for marketing/fallbacks) ---
IMGBB_API_KEY=
# After `npm run imgbb:upload-assets`, paste the printed https://i.ibb.co/... URLs (optional but recommended for home/discover/fallbacks).
# Must match `npm run site:patch-media` / Mongo `site.homeHeroUrl` — stale URLs are ignored at runtime (see src/lib/siteMedia.ts).
# NEXT_PUBLIC_IMG_BB_HOME_HERO=https://i.ibb.co/...
# NEXT_PUBLIC_IMG_BB_DISCOVER_HERO=https://i.ibb.co/...
# NEXT_PUBLIC_IMG_BB_DISCOVER_HERO_EVENTS=https://i.ibb.co/...
# NEXT_PUBLIC_IMG_BB_DISCOVER_HERO_PARTIES=https://i.ibb.co/...
# NEXT_PUBLIC_IMG_BB_DISCOVER_HERO_RESTAURANTS=https://i.ibb.co/...
# NEXT_PUBLIC_IMG_BB_DISCOVER_HERO_CAFES=https://i.ibb.co/...
# NEXT_PUBLIC_IMG_BB_DISCOVER_HERO_CULTURE=https://i.ibb.co/...
# NEXT_PUBLIC_IMG_BB_FALLBACK_LISTING=https://i.ibb.co/...
# NEXT_PUBLIC_IMG_BB_FALLBACK_MEETUP=https://i.ibb.co/...
# NEXT_PUBLIC_IMG_BB_GUIDE_CARD=https://i.ibb.co/...
# NEXT_PUBLIC_IMG_BB_LOGO_LIGHT=https://i.ibb.co/...

# --- Machine ingest API (POST /api/ingest; Bearer or X-Ingest-Key) ---
INGEST_API_KEY=
# Optional: only for local scripts (e.g. npm run ingest:listing) hitting a non-default host — not used by the Next server.
# INGEST_BASE_URL=http://localhost:3000

# --- Admin console (/admin) ---
ADMIN_PASSWORD=
# Required in production (signs cs_admin cookie). Generate: npm run env:generate
ADMIN_SESSION_SECRET=

# --- Ingest safety ---
# Local dev only: allow providers/meetupGroups.replaceAll without explicit confirm
# INGEST_ALLOW_REPLACE_ALL=true

# --- Automated curator (Vercel Cron: GET /api/cron/curator) ---
# Master switch — must be exactly "true" for the cron job or `npm run curator:run` to run discovery.
# CURATOR_ENABLED=false
#
# Web search: https://serper.dev (Google results JSON API)
# SERPER_API_KEY=
#
# Structured extraction (OpenAI Chat Completions + JSON mode)
# CURATOR_OPENAI_API_KEY=
# CURATOR_OPENAI_MODEL=gpt-4o-mini
# CURATOR_OPENAI_BASE_URL=https://api.openai.com/v1
#
# Vercel Cron: set CRON_SECRET; Vercel sends Authorization: Bearer <CRON_SECRET> on cron invocations.
# CRON_SECRET=
#
# Schedule: edit `vercel.json` (default Mondays 15:00 UTC).

# --- OpenStreetMap reviews sync (Vercel Cron: GET /api/cron/sync-reviews) ---
# Free open data (ODbL): Nominatim + Overpass + optional Wikidata P444 scores. No API key required.
# REVIEWS_SYNC_ENABLED=true
# OSM_CONTACT_EMAIL=you@example.com
# Weekly sync (default Sundays 04:30 UTC). Many bars lack star tags — sync still links the OSM page.

# --- Pesti Est (public site + newsletter) ---
# Optional override for sitemap, OG, share links, QR, and newsletter redirects.
# Default (no env): https://budapest-night.vercel.app — the live Vercel deployment.
# NEXT_PUBLIC_SITE_URL=https://budapest-night.vercel.app
# When pestiest.hu is live, set canonical host for legacy redirects (middleware):
# NEXT_PUBLIC_SITE_URL=https://pestiest.hu
# NEXT_PUBLIC_CANONICAL_HOST=pestiest.hu
# LEGACY_SITE_HOST=budapest-night.vercel.app
# NEXT_PUBLIC_PRIVACY_POLICY_URL=https://pestiest.hu/adatvedelem
#
# Newsletter email (not required yet). Without RESEND_API_KEY, subscribe stores pending signups
# and returns confirmUrl in JSON during local dev; cron digest skips send.
# RESEND_API_KEY=
# NEWSLETTER_FROM=
# CRON_SECRET=  # Vercel sends Authorization: Bearer on /api/cron/newsletter (Thu 05:00 UTC in vercel.json)
