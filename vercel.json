{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.pestiest.hu" }],
      "destination": "https://pestiest.hu/:path*",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/curator",
      "schedule": "0 15 * * 1"
    },
    {
      "path": "/api/cron/sync-reviews",
      "schedule": "30 4 * * 0"
    },
    {
      "path": "/api/cron/newsletter",
      "schedule": "0 5 * * 4"
    },
    {
      "path": "/api/cron/archive-events",
      "schedule": "15 * * * *"
    },
    {
      "path": "/api/cron/promotions",
      "schedule": "30 * * * *"
    }
  ]
}
