{
  "schemaVersion": 1,
  "gdsVersion": "2.4.3",
  "gdsRepository": "https://github.com/sovereignsquad/general-design-system",
  "productArchetype": "public-discovery",
  "supportedEntryPoints": [
    "@gds/theme/client",
    "@gds/theme/server",
    "@gds/core/client",
    "@gds/core/server",
    "@gds/admin"
  ],
  "requiredContracts": [
    "StateBlock",
    "ProductCard",
    "PublicShell",
    "AuthShell",
    "DataToolbar",
    "EmptyState",
    "ThemeToggle"
  ],
  "localAdapters": [
    {
      "contract": "theme",
      "path": "src/theme/pestiestTheme.ts",
      "status": "active"
    },
    {
      "contract": "root-provider",
      "path": "src/components/gds/MantineRoot.tsx",
      "status": "active"
    },
    {
      "contract": "icons",
      "path": "src/components/gds/icons.ts",
      "status": "active"
    },
    {
      "contract": "button",
      "path": "src/components/gds/AppButton.tsx",
      "status": "legacy-wrapper"
    },
    {
      "contract": "discovery-shell",
      "path": "src/components/gds/DiscoveryAppShell.tsx",
      "status": "active"
    },
    {
      "contract": "listing-card",
      "path": "src/components/scout/ProviderCard.tsx",
      "status": "deferred",
      "note": "ProductCard migration reverted; unique images are catalog data (content-quality agent)"
    },
    {
      "contract": "public-shell",
      "path": "src/components/scout/BudapestNightShell.tsx",
      "status": "active"
    },
    {
      "contract": "admin-shell",
      "path": "src/components/admin/AdminDashboard.tsx",
      "status": "active"
    }
  ],
  "approvedExceptions": [
    {
      "surface": "Map embed",
      "reason": "OSM iframe in provider profiles.",
      "owner": "pestiest",
      "reviewDate": "2026-06-01"
    }
  ],
  "migrationStatus": "gds-only",
  "owner": "pestiest",
  "lastReviewedAt": "2026-05-25"
}
