{
  "schemaVersion": 1,
  "gdsVersion": "2.6.5",
  "gdsRepository": "https://github.com/sovereignsquad/general-design-system",
  "productArchetype": "hybrid",
  "supportedEntryPoints": [
    "@doneisbetter/gds-theme/client",
    "@doneisbetter/gds-theme/server",
    "@doneisbetter/gds-core/client",
    "@doneisbetter/gds-core/server",
    "@doneisbetter/gds-admin/client"
  ],
  "requiredContracts": [
    "BrowseSurface",
    "PublicProductCard",
    "StateBlock",
    "AuthShell",
    "DataToolbar",
    "EmptyState",
    "ThemeToggle",
    "EditorialHero",
    "AccentPanel"
  ],
  "localAdapters": [
    {
      "contract": "theme",
      "path": "src/theme/pestiestTheme.ts",
      "status": "active",
      "notes": "createPublicBrandTheme({ flatSurfaces: true, overrides: brand/ink })"
    },
    {
      "contract": "root-provider",
      "path": "src/components/gds/MantineRoot.tsx",
      "status": "active"
    },
    {
      "contract": "icons",
      "path": "src/components/gds/icons.ts",
      "status": "active"
    },
    {
      "contract": "button",
      "path": "src/components/gds/AppButton.tsx",
      "status": "exception"
    },
    {
      "contract": "discovery-shell",
      "path": "src/components/gds/DiscoveryAppShell.tsx",
      "status": "active"
    },
    {
      "contract": "listing-card",
      "path": "src/components/scout/ProviderCard.tsx",
      "status": "active"
    },
    {
      "contract": "detail-sections",
      "path": "src/components/scout/detail",
      "status": "active"
    },
    {
      "contract": "cta-button-group",
      "path": "src/components/scout/detail/VenueProfileActions.tsx",
      "status": "active"
    },
    {
      "contract": "public-shell",
      "path": "src/components/scout/BudapestNightShell.tsx",
      "status": "exception"
    },
    {
      "contract": "admin-shell",
      "path": "src/components/admin/AdminDashboard.tsx",
      "status": "active"
    }
  ],
  "approvedExceptions": [
    {
      "surface": "Map embed",
      "category": "runtime-constraint",
      "scope": ["src/components/scout/panels/ProviderMap.tsx"],
      "allowedImplementation": "OpenStreetMap iframe embed in venue detail map panel.",
      "mustStillUse": ["Mantine layout primitives", "GDS StateBlock for map loading and error states"],
      "mustNotDo": ["Custom map rendering stack", "Raw color literals for map chrome"],
      "exitCondition": "Adopt GDS MapPanel when published in @doneisbetter/gds-core.",
      "status": "approved",
      "reason": "OSM iframe in provider profiles.",
      "owner": "pestiest",
      "reviewDate": "2026-06-01"
    },
    {
      "surface": "AppButton legacy wrapper",
      "category": "migration-bridge",
      "scope": ["src/components/gds/AppButton.tsx"],
      "allowedImplementation": "Legacy Mantine Button wrapper mapping deprecated variant names to GDS theme tokens.",
      "mustStillUse": ["@mantine/core Button", "createPublicBrandTheme brand and ink colors"],
      "mustNotDo": ["New AppButton call sites for semantic actions", "Parallel button or CTA design systems"],
      "exitCondition": "Scout and admin actions use SemanticButton or GDS ActionBar; remove AppButton.tsx.",
      "status": "temporary",
      "reason": "Gradual migration to SemanticButton where vocabulary exists.",
      "owner": "pestiest",
      "reviewDate": "2026-08-01"
    },
    {
      "surface": "Sidebar discovery shell",
      "category": "package-coverage-gap",
      "scope": [
        "src/components/scout/BudapestNightShell.tsx",
        "src/components/gds/DiscoveryAppShell.tsx"
      ],
      "allowedImplementation": "Sidebar-first discovery chrome composed from Mantine AppShell regions until upstream DiscoveryShell ships.",
      "mustStillUse": ["DiscoveryAppShell layout regions", "GDS ThemeToggle and semantic header controls"],
      "mustNotDo": ["Duplicate PublicShell top-nav layout", "New bespoke shell primitives outside adapter paths"],
      "exitCondition": "Migrate to GDS DiscoveryShell in @doneisbetter/gds-core and retire local shell adapters.",
      "status": "temporary",
      "reason": "Product uses sidebar-first layout; GDS PublicShell is top-nav. DiscoveryAppShell mirrors admin AppShell regions until DiscoveryShell ships in @doneisbetter/gds-core.",
      "owner": "pestiest",
      "reviewDate": "2026-08-01"
    }
  ],
  "compliance": {
    "documentationPaths": [
      "README.md",
      "docs/design-system-adapter.md",
      "docs/design-system-exceptions.md"
    ],
    "staleDocumentationReferences": [
      "@gds/theme",
      "@gds/core",
      "@gds/admin",
      "@gds/eslint-config",
      "@gds/compliance"
    ],
    "protectedSurfacePaths": [
      "src/components/gds",
      "src/theme/pestiestTheme.ts"
    ],
    "bannedImports": ["lucide-react", "@/components/ui"],
    "approvedThemeLanes": [
      "gdsTheme",
      "gdsDarkPublicTheme",
      "gdsFlatSurfaceTheme",
      "gdsEditorialPublicTheme",
      "createPublicBrandTheme"
    ],
    "themeOwnershipPaths": [
      "src/theme/pestiestTheme.ts",
      "src/components/gds/MantineRoot.tsx"
    ]
  },
  "migrationStatus": "in-progress",
  "owner": "pestiest",
  "lastReviewedAt": "2026-05-27",
  "packageSource": "npm:@doneisbetter/*@^2.6.5"
}
